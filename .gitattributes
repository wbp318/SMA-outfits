# Normalize line endings: store everything as LF in the repo and check out LF
# everywhere (this overrides core.autocrlf), so the working tree is identical on
# every OS and Git stops warning about CRLF conversion on Windows.
* text=auto eol=lf

# --- Explicit text types (clarity / robustness) ---
*.py     text eol=lf
*.pyi    text eol=lf
*.md     text eol=lf
*.txt    text eol=lf
*.yml    text eol=lf
*.yaml   text eol=lf
*.toml   text eol=lf
*.cfg    text eol=lf
*.ini    text eol=lf
*.json   text eol=lf
*.csv    text eol=lf
*.ipynb  text eol=lf
.gitignore     text eol=lf
.gitattributes text eol=lf

# --- Windows scripts: cmd/batch need CRLF; PowerShell & sh are fine with LF ---
*.bat    text eol=crlf
*.cmd    text eol=crlf
*.ps1    text eol=lf
*.psm1   text eol=lf
*.sh     text eol=lf

# --- Binary files: never normalize, never diff as text ---
*.png    binary
*.jpg    binary
*.jpeg   binary
*.gif    binary
*.ico    binary
*.pdf    binary
*.parquet binary
*.feather binary
*.xlsx   binary
*.zip    binary
*.gz     binary
*.whl    binary
*.pyc    binary

# --- GitHub Linguist: surface EVERY language in the repo's language stats ---
# By default Linguist counts only "programming"/"markup" languages and hides
# "data" and "prose" (YAML, TOML, JSON, CSV, Markdown, Text, INI, shell, etc.).
# Force them all detectable so the language bar shows every language present.
*.py            linguist-detectable=true
*.pyi           linguist-detectable=true
*.md            linguist-detectable=true
*.markdown      linguist-detectable=true
*.txt           linguist-detectable=true
*.yml           linguist-detectable=true
*.yaml          linguist-detectable=true
*.toml          linguist-detectable=true
*.cfg           linguist-detectable=true
*.ini           linguist-detectable=true
*.json          linguist-detectable=true
*.csv           linguist-detectable=true
*.tsv           linguist-detectable=true
*.ipynb         linguist-detectable=true
*.ps1           linguist-detectable=true
*.psm1          linguist-detectable=true
*.bat           linguist-detectable=true
*.cmd           linguist-detectable=true
*.sh            linguist-detectable=true
requirements*.txt linguist-detectable=true
.gitignore      linguist-detectable=true
.gitattributes  linguist-detectable=true

# Make sure nothing is silently excluded from the stats.
*               -linguist-documentation -linguist-vendored -linguist-generated
